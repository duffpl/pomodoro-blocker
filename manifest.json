{
  "manifest_version": 3,
  "name": "Pomodoro Blocker",
  "version": "1.0.0",
  "description": "Pomodoro focus timer that blocks distracting sites during work intervals.",
  "permissions": ["declarativeNetRequest", "storage", "alarms", "notifications", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Pomodoro Blocker",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "64": "assets/icon-64.png",
      "128": "assets/icon-128.png"
    }
  },
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "64": "assets/icon-64.png",
    "128": "assets/icon-128.png"
  },
  "web_accessible_resources": [
    { "resources": ["blocked.html"], "matches": ["<all_urls>"] }
  ]
}
